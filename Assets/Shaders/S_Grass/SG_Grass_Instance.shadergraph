{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "86cc5e2a2422464f985e4127a3a85dc0",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "GrassTint (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 2516.666748046875,
            "y": 1406.6666259765625,
            "width": 238.66650390625,
            "height": 222.66650390625
        }
    },
    "m_Slots": [
        {
            "m_Id": "a074372b256b4fffbfa1d3fee5f30807"
        },
        {
            "m_Id": "ff4b8e91e86d4dc5950139efb03c4648"
        },
        {
            "m_Id": "91186c30533a4a22bedbbd0a6775ee79"
        },
        {
            "m_Id": "6e161375d52441019a1ef26a2eb10163"
        },
        {
            "m_Id": "a3daef11325a46c9a88726a0dd217879"
        },
        {
            "m_Id": "7d6a09960303406e86a597b56b5cf86e"
        },
        {
            "m_Id": "1d8a63b6d5a646c9b69f4d2fa82ff22b"
        },
        {
            "m_Id": "415ae799261d4254801b5ebd4adfb9c5"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "GrassTint",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float2 p = worldXZ * NoiseScale;\r\n\r\nfloat2 i = floor(p);\r\nfloat2 f = frac(p);\r\n\r\nf = f * f * (3.0 - 2.0 * f);\r\n\r\nfloat a = frac(sin(dot(i, float2(127.1, 311.7))) * 43758.5453123);\r\nfloat b = frac(sin(dot(i + float2(1.0, 0.0), float2(127.1, 311.7))) * 43758.5453123);\r\nfloat c = frac(sin(dot(i + float2(0.0, 1.0), float2(127.1, 311.7))) * 43758.5453123);\r\nfloat d = frac(sin(dot(i + float2(1.0, 1.0), float2(127.1, 311.7))) * 43758.5453123);\r\n\r\nfloat x1 = lerp(a, b, f.x);\r\nfloat x2 = lerp(c, d, f.x);\r\nfloat n = lerp(x1, x2, f.y);\r\n\r\nn = saturate((n - 0.5) * NoiseStrength + 0.5);\r\nn = saturate(pow(n, BlendSharpness));\r\n\r\nif (n < 0.5)\r\n{\r\n    GrassTint = lerp(DarkGrassColor.rgb, MidGrassColor.rgb, n * 2.0);\r\n}\r\nelse\r\n{\r\n    GrassTint = lerp(MidGrassColor.rgb, LightGrassColor.rgb, (n - 0.5) * 2.0);\r\n}"
}

